{
  "name": "@nats-kit/nestjs",
  "version": "0.1.0",
  "description": "NestJS module for NATS JetStream and KV, built on @nats-kit/core.",
  "keywords": [
    "nats",
    "nestjs",
    "nest",
    "jetstream",
    "kv",
    "messaging",
    "microservices"
  ],
  "license": "MIT",
  "homepage": "https://github.com/anatoly-lab/nats-kit/tree/main/packages/nats-kit-nestjs#readme",
  "bugs": {
    "url": "https://github.com/anatoly-lab/nats-kit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anatoly-lab/nats-kit.git",
    "directory": "packages/nats-kit-nestjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!src/**/__tests__/**",
    "!src/package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "tshy": {
    "selfLink": false,
    "exports": {
      ".": "./src/index.ts",
      "./package.json": "./package.json"
    },
    "project": "./tsconfig.build.json",
    "exclude": [
      "src/**/*.test.ts",
      "src/**/__tests__/**"
    ]
  },
  "scripts": {
    "build": "tshy",
    "prepublishOnly": "tshy",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "clean": "rimraf dist .turbo .tshy-build .tsbuildinfo *.tsbuildinfo"
  },
  "dependencies": {
    "@nats-kit/core": "workspace:^"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "reflect-metadata": ">=0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/common": "11.1.27",
    "@nestjs/core": "11.1.27",
    "@nestjs/testing": "11.1.27",
    "@types/node": "26.0.1",
    "reflect-metadata": "0.2.2",
    "rimraf": "6.1.3",
    "rxjs": "7.8.2",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/commonjs/index.d.ts",
        "default": "./dist/commonjs/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/commonjs/index.js",
  "types": "./dist/commonjs/index.d.ts",
  "module": "./dist/esm/index.js"
}
