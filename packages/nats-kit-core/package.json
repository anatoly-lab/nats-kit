{
  "name": "@nats-kit/core",
  "version": "0.1.0",
  "description": "Framework-free NATS toolkit for Node: resilient connection runner, JetStream and KV services, and reconnect-aware helpers.",
  "keywords": [
    "nats",
    "jetstream",
    "kv",
    "key-value",
    "pubsub",
    "messaging",
    "microservices"
  ],
  "license": "MIT",
  "homepage": "https://github.com/anatoly-lab/nats-kit/tree/main/packages/nats-kit-core#readme",
  "bugs": {
    "url": "https://github.com/anatoly-lab/nats-kit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anatoly-lab/nats-kit.git",
    "directory": "packages/nats-kit-core"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!src/**/__tests__/**",
    "!src/package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "tshy": {
    "selfLink": false,
    "exports": {
      ".": "./src/index.ts",
      "./package.json": "./package.json"
    },
    "project": "./tsconfig.build.json",
    "exclude": [
      "src/**/*.test.ts",
      "src/**/__tests__/**"
    ]
  },
  "scripts": {
    "build": "tshy",
    "prepublishOnly": "tshy",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "clean": "rimraf dist .turbo .tshy-build .tsbuildinfo *.tsbuildinfo"
  },
  "dependencies": {
    "@nats-io/jetstream": "^3.4.0",
    "@nats-io/kv": "^3.4.0",
    "@nats-io/transport-node": "^3.4.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "rimraf": "6.1.3",
    "rxjs": "7.8.2",
    "testcontainers": "12.0.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/commonjs/index.d.ts",
        "default": "./dist/commonjs/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/commonjs/index.js",
  "types": "./dist/commonjs/index.d.ts",
  "module": "./dist/esm/index.js"
}
