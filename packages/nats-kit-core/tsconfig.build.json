{
  // tshy build config. `verbatimModuleSyntax: false` lets tshy's CommonJS pass
  // emit `require`/`exports` from ESM source without TS1286; `incremental` off
  // avoids a buildinfo path that points outside tshy's relocated outDir. The
  // `typecheck` script still uses the strict ESM-only `tsconfig.json`.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "verbatimModuleSyntax": false,
    "incremental": false
  }
}
